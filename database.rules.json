{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      "$rid": {
        "config": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid)",
          "password": {
            ".read": "auth != null && data.parent().parent().child('players').hasChild(auth.uid)"
          }
        },
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && (!data.exists() || $uid === auth.uid || data.parent().parent().child('config/hostId').val() === auth.uid)"
          }
        },
        "mapData": {
          ".read": "auth != null",
          ".write": "auth != null && data.parent().child('players').hasChild(auth.uid)"
        },
        "logs": {
          ".read": "auth != null",
          ".write": "auth != null && data.parent().child('players').hasChild(auth.uid)"
        },
        "chat": {
          ".read": "auth != null",
          ".write": "auth != null && data.parent().child('players').hasChild(auth.uid)"
        }
      }
    }
  }
}
