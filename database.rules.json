{
  "rules": {
    "stats": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "presence": {
      ".read": "auth != null",
      "$uid": {
         ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rooms": {
      ".read": "auth != null",
      "$rid": {
        ".write": "auth != null && (!data.exists() || data.child('players').hasChild(auth.uid) || data.child('config/hostId').val() === auth.uid)",
        "config": {
          ".read": "auth != null",
          "password": {
            ".read": "auth != null && data.parent().parent().child('players').hasChild(auth.uid)"
          }
        },
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || data.parent().parent().child('config/hostId').val() === auth.uid)"
          }
        },
        "mapData": {
          ".read": "auth != null"
        },
        "logs": {
          ".read": "auth != null"
        },
        "chat": {
          ".read": "auth != null"
        }
      }
    }
  }
}
